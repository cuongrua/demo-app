// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model Role {
  id    String @id @default(uuid())
  name  String @unique // Ví dụ: 'ADMIN', 'USER'
  users User[] // Quan hệ 1-nhiều với User
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  password  String   // Nên mã hóa password trong thực tế
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id])
  posts     Post[]   // Quan hệ 1-nhiều với Post
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt @default(now())
}

model Post {
  id        String @id @default(uuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt @default(now())

  // Map model "Post" thành tên bảng "posts" trong database nếu bạn muốn số nhiều
  @@map("posts") 
}